# =============================================
# Unithink School — Environment Variables
# =============================================
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to git.
# =============================================

# ------------------------------------------
# CONTACT FORM (Web3Forms — FREE service)
# ------------------------------------------
# 1. Go to https://web3forms.com
# 2. Enter: unithink.school@gmail.com
# 3. Check your inbox and copy the access key
# 4. Paste it below
# ------------------------------------------
VITE_WEB3FORMS_KEY=your_access_key_here

# ------------------------------------------
# GOOGLE ANALYTICS 4
# ------------------------------------------
# Format: G-XXXXXXXXXX
# Also uncomment the GA4 script block in index.html
# ------------------------------------------
VITE_GA4_ID=G-XXXXXXXXXX

# ------------------------------------------
# GEMINI API KEY (future AI features)
# Keep server-side only — never expose in client bundle
# ------------------------------------------
GEMINI_API_KEY=your_gemini_key_here
